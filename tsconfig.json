{
    "compilerOptions": {
        "module": "esnext",
        "esModuleInterop": true,
        "target": "es2020",
        "moduleResolution": "node",
        "sourceMap": true,
        "rootDir": "./src",
        "strict": true,
        "resolveJsonModule": true,
        "noImplicitAny": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "types": ["node", "jest"],
        "allowSyntheticDefaultImports": true,
        "declaration": true,
        "declarationMap": true,
        "isolatedModules": true,
        "lib": ["es2020", "DOM"],
        "paths": {
            "gscrap/*": ["./src/*"]
        },
    }
}