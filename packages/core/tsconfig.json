{
    "compilerOptions": {
        "target": "es2020",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "rootDir": "./src",
        "outDir": "./dist",
        "strict": true,
        "types": ["node", "jest"],
        "declaration": true,
        "emitDeclarationOnly": true,
        "declarationDir": "./dist/types"
    },
    "include": ["**/*.ts"]
}